{
  "id": "ZG-004",
  "suite": "zigperf",
  "prompt": [
    "Complete this Zig grayscale raster mask module.",
    "It should classify pixels from local neighborhood intensity, write results into caller-owned output storage, return useful stats, and include tests plus a benchmark."
  ],
  "fixtureMapping": {
    "build.zig": "skills-evals/fixtures/eval-cases/ZG-004/build.zig",
    "src/main.zig": "skills-evals/fixtures/eval-cases/ZG-004/src/main.zig"
  },
  "expectedSkills": [],
  "disallowedSkills": [],
  "expectedRefs": [],
  "tools": ["read", "edit", "write", "bash"],
  "sandbox": true,
  "fileAssertions": [
    {
      "path": "src/main.zig",
      "mustContain": ["classifyCrossBlurInto", "GrayImage", "MaskStats", "test"],
      "mustNotContain": ["NotImplemented", "PLACEHOLDER_DO_NOT_KEEP"],
      "maxNonEmptyLines": 400
    }
  ],
  "verificationCommands": [
