{
  "id": "CD-301",
  "suite": "events",
  "prompt": [
    "I have an event ingestion pipeline with type definitions in events/types.py, a parser in events/parse.py, the ingestion entry point in events/ingest.py, and downstream handlers in events/handlers.py.",
    "All upstream producers have migrated to the v2 event contract.",
    "Update the ingestion pipeline so that downstream handlers receive typed EventV2 objects from events/types.py instead of raw dicts."
  ],
  "fixtureMapping": {
    "events/types.py": "skills-evals/fixtures/events/cd301/events/types.py",
    "events/parse.py": "skills-evals/fixtures/events/cd301/events/parse.py",
    "events/ingest.py": "skills-evals/fixtures/events/cd301/events/ingest.py",
    "events/handlers.py": "skills-evals/fixtures/events/cd301/events/handlers.py"
  },
  "expectedSkills": [],
  "disallowedSkills": [],
  "expectedRefs": [],
  "tools": ["read", "edit", "write"],
  "sandbox": true,
  "fileAssertions": [
    {
      "path": "events/ingest.py",
      "mustContain": ["EventV2"],
      "mustNotContain": ["PLACEHOLDER"]
    }
  ],
  "persistArtifacts": false,
  "notes": "Migration eval: v1-to-v2 event cutover. Skill agent should remove or-chain compat and use typed EventV2 throughout, not add defensive wrappers.",
  "readDenyPaths": [],
  "variants": [
    {
      "tag": "skill",
      "bootstrapProfile": "full_payload",
      "expectedSkills": ["coding"],
      "expectedRefs": ["skills/code-smell-detection/references/ai-code-smell.md"],
      "skillSet": ["coding"],
      "requireSkillFileRead": true,
      "fileAssertions": [
        {
          "path": "events/ingest.py",
          "mustContain": ["EventV2"],
          "mustNotContain": ["PLACEHOLDER", "EventV1"]
        },
        {
          "path": "events/parse.py",
          "mustNotContain": [".get(\"user_id\")", "or raw.get(\"user_id\")", "EventV1"]
        }
      ]
    },
    {
      "tag": "noskill",
      "bootstrapProfile": "no_payload",
      "disallowedSkills": ["coding", "design", "housekeeping"]
    }
  ]
}
